    {
      "annotations": {
        "readOnlyHint": false
      },
      "description": "Render a Mermaid diagram to PNG AND embed the source in the PNG's iTXt metadata (a per-artifact UUID + the source's SHA-256). ALWAYS use this instead of calling `mmdc` directly — raw `mmdc` skips the embedding and breaks lossless round-trips and document publishing. Rendering is pure Rust (no browser). Input: `source` (Mermaid text) + `output_path`. Returns `{ png_path, uuid, sha256, bytes }`; recover the source later with `extract`.",
      "inputSchema": {
        "properties": {
          "output_path": {
            "description": "Where to write the PNG.",
            "type": "string"
          },
          "source": {
            "description": "Mermaid diagram source.",
            "type": "string"
          }
        },
        "required": [
          "source",
          "output_path"
        ],
        "type": "object"
      },
      "name": "mermaid_to_png",
      "outputSchema": {
        "properties": {
          "bytes": {
            "type": "integer"
          },
          "kind": {
            "const": "mermaid_to_png",
            "description": "Payload discriminator — the tool name."
          },
          "png_path": {
            "type": "string"
          },
          "sha256": {
            "description": "SHA-256 of the Mermaid source.",
            "type": "string"
          },
          "tool_error": {
            "description": "Business failure — the tool ran and said \"no\". Absent on success. (At the MCP boundary a business failure surfaces as an isError:true result instead of riding inside a success payload.)",
            "properties": {
              "code": {
                "description": "Stable machine code, e.g. no_live_app.",
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ],
            "type": "object"
          },
          "uuid": {
            "description": "Per-artifact id embedded in the PNG.",
            "type": "string"
          },
          "v": {
            "const": 1,
            "description": "Payload schema version."
          }
        },
        "required": [
          "v",
          "kind",
          "png_path",
          "uuid",
          "sha256",
          "bytes"
        ],
        "type": "object"
      }
    },
    {
